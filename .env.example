# ─── AI Providers ────────────────────────────────────────────────────────────
#
# ANTHROPIC_API_KEY (PRIMARY): Server-side only — set in Vercel Dashboard,
# NOT in this file. Used by api/ai/*.ts serverless functions.
# Go to: Vercel Dashboard → Settings → Environment Variables → Add ANTHROPIC_API_KEY
#
# VITE_GEMINI_API_KEY (FALLBACK): Client-side Gemini key for fallback + image generation.
VITE_GEMINI_API_KEY="your_google_gemini_api_key_here"

# Legacy alias (used by some files via vite.config define)
GEMINI_API_KEY="your_google_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
