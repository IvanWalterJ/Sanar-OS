# ─── AI Providers ────────────────────────────────────────────────────────────
#
# ANTHROPIC_API_KEY (PRIMARY text): Server-side only — set in Vercel Dashboard,
# NOT in this file. Used by api/ai/generate.ts serverless functions.
# Go to: Vercel Dashboard → Settings → Environment Variables → Add ANTHROPIC_API_KEY
#
# OPENAI_API_KEY (PRIMARY image, gpt-image-2): Server-side only — set in Vercel
# Dashboard. Used by api/ai/image.ts. NEVER expose this key to the browser
# (no VITE_ prefix). Recommended: use a dedicated key with a monthly usage
# limit to contain blast radius if leaked.
#
# VITE_GEMINI_API_KEY (FALLBACK): Client-side Gemini key. Used as image
# fallback cascade when gpt-image-2 fails, and for misc text tasks.
VITE_GEMINI_API_KEY="your_google_gemini_api_key_here"

# Legacy alias (used by some files via vite.config define)
GEMINI_API_KEY="your_google_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
